PORT=3000
DB_PATH=./data/renfe.db
POLL_INTERVAL_MS=60000
FETCH_TIMEOUT_MS=12000
STALE_TRAIN_SECONDS=180
SNAPSHOT_RETENTION_HOURS=96
SNAPSHOT_HEARTBEAT_SECONDS=300
COMPACT_EVERY_RUNS=15
STATIONS_REFRESH_HOURS=24
RENFE_ENDPOINTS=https://tiempo-real.largorecorrido.renfe.com/renfe-visor/flotaLD.json
STATIONS_ENDPOINT=https://tiempo-real.largorecorrido.renfe.com/data/estaciones.geojson
CACHE_FILE=./data/cache/flotaLD.latest.json
API_KEY_TTL_SECONDS=900
API_RATE_LIMIT_MS=1000
RAW_MAX_TRAINS=5000
HISTORY_RETENTION_DAYS=0
RECOVERY_LOOKBACK_HOURS=72

# Migración/warehouse Postgres (script migrate:pg)
POSTGRES_URL=postgresql://renfe:renfe@localhost:5432/renfe_analytics
SQLITE_PATH=./data/renfe.db
MIGRATION_BATCH_SIZE=500
AUTO_MIGRATE_PG_ON_START=0

# Bootstrap Docker (importar datos existentes al volumen persistente en primer arranque)
BOOTSTRAP_SQLITE_PATH=
BOOTSTRAP_CACHE_PATH=
